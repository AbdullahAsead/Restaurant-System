<Window x:Class="Restaurant_System.ViewEditAdmins"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Edit Admins"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="20">
        <StackPanel>

            <!-- العنوان -->
            <TextBlock Text="Admins List"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1976D2"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- شريط البحث -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15">
                <TextBlock Text="Search:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"/>
                <TextBox x:Name="txtSearch"
                         Width="200"
                         Height="28"
                         BorderBrush="#1976D2"
                         BorderThickness="1"
                         Padding="5"
                         TextChanged="txtSearch_TextChanged"/>
                <Button Content="Clear"
                        Width="70"
                        Height="28"
                        Background="#F44336"
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="10,0,0,0"
                        Click="ClearSearch_Click"/>
            </StackPanel>

            <!-- جدول الأدمنز -->
            <DataGrid x:Name="AdminsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Margin="0,0,0,10"
                      RowHeight="35">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*" />
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                    <DataGridTextColumn Header="Password" Binding="{Binding Password}" Width="*" />

                    <DataGridTemplateColumn Header="Edit" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✏️"
                                        Background="#FF9800"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        Padding="5"
                                        Click="Edit_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Delete" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑️"
                                        Background="#F44336"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        Padding="5"
                                        Click="Delete_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Window>
