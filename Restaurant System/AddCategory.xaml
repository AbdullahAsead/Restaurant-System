<Window x:Class="Restaurant_System.AddCategory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Category" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Category Name -->
            <RowDefinition Height="*"/>
            <!-- Items DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Finish Button -->
        </Grid.RowDefinitions>

        <!-- Category Section -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Category Name:" VerticalAlignment="Center" FontSize="16" Width="120"/>
            <TextBox x:Name="CategoryNameTextBox" Height="30" Width="400"/>
        </StackPanel>

        <!-- Items DataGrid -->
        <DataGrid x:Name="ItemsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  FontSize="14"
                  RowHeight="35"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  ItemsSource="{Binding Items}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Item Name"
                                    Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="2*"/>
                <DataGridTextColumn Header="Price"
                                    Binding="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1*"/>
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="3*"/>
                <DataGridTextColumn Header="Weight"
                                    Binding="{Binding Weight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1*"/>
                <DataGridTextColumn Header="Barcode"
                                    Binding="{Binding Barcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.5*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Finish Button -->
        <Button Content="💾 Finish"
                Grid.Row="2"
                HorizontalAlignment="Right"
                Height="45"
                Width="120"
                Background="#2196F3"
                Foreground="White"
                FontWeight="Bold"
                Margin="0,15,0,0"
                Click="Finish_Click"/>
    </Grid>
</Window>
