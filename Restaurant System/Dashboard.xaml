<Window x:Class="Restaurant_System.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant_System"
        mc:Ignorable="d"
        Title="Dashboard"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="White">

    <Window.Resources>
        <DropShadowEffect x:Key="ButtonShadow" ShadowDepth="2" Color="Gray" BlurRadius="5" />

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="190"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🔹 العنوان العلوي -->
        <DockPanel Background="#2196F3" Height="70" VerticalAlignment="Top">
            <TextBlock Text="لوحة تحكم الأدمن" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,10,0,0"/>
        </DockPanel>

        <!-- 🔹 المحتوى الرئيسي -->
        <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- 🔹 صف جديد لزر تقفيل شيفت الدليفري -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ✅ إدارة الكاشير -->
                <GroupBox Header="إدارة الكاشير" FontWeight="Bold" FontSize="16" Margin="10" Grid.Row="0" Grid.Column="0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="إضافة كاشير" Style="{StaticResource ActionButtonStyle}" Click="AddAdmin_Click"/>
                        <Button Content="عرض/تعديل الكاشير" Style="{StaticResource ActionButtonStyle}" Click="ViewEditAdmins_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- ✅ موظفي التوصيل -->
                <GroupBox Header="موظفي التوصيل" FontWeight="Bold" FontSize="16" Margin="10" Grid.Row="0" Grid.Column="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="إضافة موظف" Style="{StaticResource ActionButtonStyle}" Click="AddDeliveryEmployee_Click"/>
                        <Button Content="عرض/تعديل الموظفين" Style="{StaticResource ActionButtonStyle}" Click="ViewEditDeliveryEmployees_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- ✅ ملخص الطلبات -->
                <GroupBox Header="ملخص الطلبات" FontWeight="Bold" FontSize="16" Margin="10" Grid.Row="0" Grid.Column="2">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="عرض ملخص الطلبات" Style="{StaticResource ActionButtonStyle}" Click="ViewOrdersSummary_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- ✅ تقرير المبيعات -->
                <GroupBox Header="تقرير المبيعات" FontWeight="Bold" FontSize="16" Margin="10" Grid.Row="1" Grid.Column="0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="عرض تقرير المبيعات" Style="{StaticResource ActionButtonStyle}" Click="ViewReports_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- ✅ تصفير الورديه -->
                <GroupBox Header="تصفير الورديه" FontWeight="Bold" FontSize="16" Margin="10" Grid.Row="1" Grid.Column="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="فتح نافذة التصفير" Style="{StaticResource ActionButtonStyle}" Click="OpenClearSalesWindow_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- ✅ مستخدمي لوحة التحكم -->
                <GroupBox Header="مستخدمي لوحة التحكم" FontWeight="Bold" FontSize="16" Margin="10" Grid.Row="1" Grid.Column="2">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="إضافة مدير" Style="{StaticResource ActionButtonStyle}" Click="AddDashboardUser_Click"/>
                        <Button Content="تعديل بيانات المدير" Style="{StaticResource ActionButtonStyle}" Click="EditDashboardUser_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- ✅ إدارة مناطق التوصيل -->
                <GroupBox Header="إدارة مناطق التوصيل" FontWeight="Bold" FontSize="16" Margin="10" Grid.Row="2" Grid.Column="0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="إدارة المناطق" Style="{StaticResource ActionButtonStyle}" Click="ManageDeliveryPlaces_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- ✅ 🔹 جروب بوكس لتقفيل شيفت الدليفري -->
                <GroupBox Header="تـقـفـيـل شـيـفـت الـديـلـيـفـري" 
                          FontWeight="Bold" 
                          FontSize="16"
                          Grid.Row="2" 
                          Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="🚴‍♂️ فتح نافذة تقفيل الدليفري" 
                                Style="{StaticResource ActionButtonStyle}"
                                Width="230"
                                Background="#1976D2"
                                Click="OpenDeliveryClosingForAdmin_Click"/>
                    </StackPanel>
                </GroupBox>

            </Grid>
        </ScrollViewer>

        <!-- 🔹 زر العودة -->
        <Grid Grid.Row="2" Margin="10">
            <Button Content="← Back"
                    Width="90"
                    Height="41"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="Back_Click" Margin="8,0,0,8"/>
        </Grid>
    </Grid>
</Window>
