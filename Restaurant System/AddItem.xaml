<Window x:Class="Restaurant_System.AddItem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Item"
        Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- عنوان النافذة -->
        <TextBlock Text="➕ Add New Items"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#333"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

        <!-- DataGrid -->
        <DataGrid x:Name="ItemsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Items}"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  FontSize="14"
                  RowHeight="35"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="2*"/>
                <DataGridTextColumn Header="Price"
                                    Binding="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1*"/>
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="2*"/>
                <DataGridTextColumn Header="Weight"
                                    Binding="{Binding Weight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1*"/>
                <DataGridTextColumn Header="Barcode"
                                    Binding="{Binding Barcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.5*"/>

                <DataGridTemplateColumn Header="Category" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CategoryName}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding CategoryId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      MinWidth="120"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- زر الحفظ -->
        <Button Content="💾 Save Items"
                Grid.Row="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Height="45"
                Width="200"
                Background="#2196F3"
                Foreground="White"
                FontWeight="Bold"
                Click="SaveItems_Click"/>
    </Grid>
</Window>
