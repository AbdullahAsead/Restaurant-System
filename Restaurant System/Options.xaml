<Window x:Class="Restaurant_System.Options"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Options"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <Window.Resources>
        <!-- 🌟 تأثير ظل للأزرار -->
        <DropShadowEffect x:Key="ButtonShadow" Color="#888" BlurRadius="8" ShadowDepth="3"/>
        <!-- 🌟 تأثير ظل للنص العلوي (لوجو نصي) -->
        <DropShadowEffect x:Key="TextShadow" Color="#555" BlurRadius="4" ShadowDepth="2"/>

        <!-- 🌟 ستايل الأزرار -->
        <Style x:Key="MainOptionButton" TargetType="Button">
            <Setter Property="Width" Value="300"/>
            <Setter Property="Height" Value="65"/>
            <Setter Property="Margin" Value="0,12,0,12"/>
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0D47A1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- للعنوَن واللوجو -->
            <RowDefinition Height="*"/>
            <!-- للأزرار -->
        </Grid.RowDefinitions>

        <!-- 🌟 كتلة اللوجو والنص معًا في أعلى منتصف الصفحة -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,20">
            <!-- اللوجو -->
            <Border Width="150" Height="150" CornerRadius="20" Background="White" Padding="8"
                    Margin="0,0,20,0" Effect="{StaticResource ButtonShadow}">
                <Image Source="/images/AbuSoliman.png" Stretch="UniformToFill"/>
            </Border>
            <!-- اسم المطعم -->
            <TextBlock Text="مطعم أبو سليمان"
                       FontSize="48"
                       FontWeight="Bold"
                       Foreground="#1976D2"
                       VerticalAlignment="Center"
                       FontFamily="Cairo"
                       Effect="{StaticResource TextShadow}"/>
        </StackPanel>

        <!-- 🌟 الأزرار في منتصف الصفحة -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="🧾  الطلبات"
                    Style="{StaticResource MainOptionButton}"
                    Click="Order_Click"/>
            <Button Content="📊  لوحة التحكم (المدير)"
                    Style="{StaticResource MainOptionButton}"
                    Click="Dashboard_Click"/>
            <Button Content="👨‍💼  صلاحيات الكاشير"
                    Style="{StaticResource MainOptionButton}"
                    Click="CashierPermissions_Click"/>
            <Button Content="⚙️  إعدادات الطباعة"
                    Style="{StaticResource MainOptionButton}"
                    Click="PrinterSettings_Click"/>
        </StackPanel>
    </Grid>
</Window>
