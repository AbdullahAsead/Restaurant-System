<Window x:Class="Restaurant_System.ManageDeliveryPlaces"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدارة مناطق التوصيل"
        WindowStartupLocation="CenterScreen"
        Height="560" Width="880"
        ResizeMode="NoResize"
        Background="#F9FAFB">

    <Border CornerRadius="15" Background="White" Padding="20" Margin="15" BorderBrush="#1976D2" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- العنوان -->
                <RowDefinition Height="Auto"/>
                <!-- الإدخال -->
                <RowDefinition Height="Auto"/>
                <!-- البحث -->
                <RowDefinition Height="*"/>
                <!-- الجدول -->
            </Grid.RowDefinitions>

            <!-- ✅ العنوان -->
            <TextBlock Text="إدارة مناطق التوصيل"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1976D2"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"
                       Grid.Row="0"/>

            <!-- ✅ إضافة منطقة جديدة -->
            <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <TextBlock Text="اسم المنطقة:" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox x:Name="PlaceNameTextBox"
                             Width="220"
                             Height="32"
                             FontSize="15"
                             Padding="5"
                             BorderBrush="#1976D2" BorderThickness="1" />
                </StackPanel>

                <StackPanel Margin="10">
                    <TextBlock Text="سعر التوصيل:" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox x:Name="DeliveryFeeTextBox"
                             Width="120"
                             Height="32"
                             FontSize="15"
                             Padding="5"
                             BorderBrush="#1976D2" BorderThickness="1" />
                </StackPanel>

                <Button Content="➕ إضافة"
                        Width="120"
                        Height="42"
                        Background="#1976D2"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="15"
                        Margin="25,25,0,0"
                        Cursor="Hand"
                        BorderThickness="0"
                        Click="AddPlace_Click"/>
            </StackPanel>

            <!-- ✅ البحث -->
            <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center" Margin="0,5,0,15">
                <TextBlock Text="🔍 بحث:" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="SearchTextBox"
                         Width="300"
                         Height="34"
                         FontSize="15"
                         Padding="5"
                         BorderBrush="#1976D2"
                         BorderThickness="1"
                         TextChanged="SearchTextBox_TextChanged"
                         ToolTip="ابحث باسم المنطقة أو بسعر التوصيل (مثال: 10)"/>
            </StackPanel>

            <!-- ✅ الجدول -->
            <DataGrid x:Name="PlacesDataGrid"
                      Grid.Row="3"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      FontSize="15"
                      Margin="0,10,0,0"
                      RowHeight="38"
                      AlternatingRowBackground="#F1F5FB"
                      HeadersVisibility="Column"
                      BorderBrush="#1976D2"
                      BorderThickness="0.7">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="المعرف" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="اسم المنطقة" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="سعر التوصيل (ج)" Binding="{Binding DeliveryFee}" Width="150"/>

                    <DataGridTemplateColumn Header="خيارات" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="تعديل"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            Width="80"
                                            Height="30"
                                            Margin="5,0"
                                            Cursor="Hand"
                                            Click="EditPlace_Click"/>

                                    <Button Content="حذف"
                                            Background="#E53935"
                                            Foreground="White"
                                            Width="80"
                                            Height="30"
                                            Margin="5,0"
                                            Cursor="Hand"
                                            Click="DeletePlace_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</Window>
