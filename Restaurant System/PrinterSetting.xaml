<Window x:Class="Restaurant_System.PrinterSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إعدادات الطباعة"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FAFAFA"
        Height="350" Width="600">
    <Border CornerRadius="12" BorderBrush="#2196F3" BorderThickness="2" Margin="16" Padding="18" Background="White">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="460">
            <TextBlock Text="⚙️ إعدادات الطباعة"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2196F3"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <!-- تفعيل طابعة المطبخ -->
            <CheckBox x:Name="chkEnableKitchenPrinter"
                      Content="تفعيل طابعة المطبخ"
                      FontSize="18"
                      Margin="6,6,6,6"
                      Foreground="Black"/>

            <!-- تفعيل طباعة بونين -->
            <CheckBox x:Name="chkEnableTwoReceipts"
                      Content="تفعيل طباعة بونين (نسختين)"
                      FontSize="18"
                      Margin="6,6,6,6"
                      Foreground="Black"/>

            <!-- وصف بسيط -->
            <TextBlock Text="ملاحظة: يتم حفظ الإعدادات محليًا وسيتم تطبيقها عند طباعة الفواتير."
                       FontSize="12"
                       Foreground="#666"
                       TextWrapping="Wrap"
                       Margin="6,10,6,0"
                       HorizontalAlignment="Center"/>

            <!-- أزرار حفظ / رجوع -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="btnSave"
                        Content="💾 حفظ الإعدادات"
                        Width="180"
                        Height="44"
                        Margin="8,0,8,0"
                        Background="#2196F3"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="15"
                        Cursor="Hand"
                        Click="btnSave_Click"/>

                <Button x:Name="btnBack"
                        Content="↩ رجوع"
                        Width="120"
                        Height="44"
                        Margin="8,0,8,0"
                        Background="#757575"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="15"
                        Cursor="Hand"
                        Click="btnBack_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
