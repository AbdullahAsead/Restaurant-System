<Window x:Class="Restaurant_System.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تقرير المبيعات"
        WindowStartupLocation="CenterScreen"
        Width="900" Height="650"
        Background="White"
        FlowDirection="RightToLeft">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- العنوان -->
        <TextBlock Text="ملخص المبيعات"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#2196F3"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- البحث والتاريخ -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,10"
                    Grid.Row="1">
            <TextBlock Text="بحث باسم المنتج: "
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Margin="0,0,10,0"/>
            <TextBox x:Name="txtSearchProduct"
                     Width="200"
                     Height="28"
                     BorderBrush="#1976D2"
                     BorderThickness="1"
                     Padding="5"
                     TextChanged="txtSearchProduct_TextChanged"
                     Margin="0,0,20,0"/>

            <TextBlock Text="اختيار التاريخ:"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Margin="0,0,10,0"/>
            <DatePicker x:Name="DatePickerFilter"
                        Width="150"
                        SelectedDateFormat="Short"
                        SelectedDateChanged="DatePickerFilter_SelectedDateChanged"/>
        </StackPanel>

        <!-- جدول المنتجات -->
        <GroupBox Header="تفاصيل المنتجات"
                  FontWeight="Bold"
                  Grid.Row="2"
                  Margin="0,0,0,10">
            <DataGrid x:Name="SalesSummaryItems"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Margin="0,5,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="2*" />
                    <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="*" />
                    <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, StringFormat=N2}" Width="*" />
                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total, StringFormat=N2}" Width="*" />
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding SaleDate}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- جدول الطلبات -->
        <GroupBox Header="تفاصيل الطلبات"
                  FontWeight="Bold"
                  Grid.Row="3"
                  Margin="0,0,0,10">
            <DataGrid x:Name="OrdersSummaryItems"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Margin="0,5,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="رقم الطلب" Binding="{Binding OrderId}" Width="*" />
                    <DataGridTextColumn Header="قيمة التوصيل" Binding="{Binding DeliveryFee, StringFormat=N2}" Width="*" />
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding Date}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- المجاميع -->
        <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock x:Name="TotalSalesText"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="Green"
                       Margin="0,0,20,0"/>
            <TextBlock x:Name="TotalDeliveryText"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="DarkOrange"
                       Margin="0,0,20,0"/>
            <TextBlock x:Name="GrandTotalText"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="Blue"/>
        </StackPanel>
    </Grid>
</Window>
