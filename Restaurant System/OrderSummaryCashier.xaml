<Window x:Class="Restaurant_System.OrderSummaryCashier"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ملخص الطلبات - Cashier"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔹 العنوان -->
        <TextBlock Text="ملخص الطلبات (Cashier)"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#1976D2"
                   HorizontalAlignment="Center"
                   Margin="0,6"/>

        <!-- 🔹 شريط البحث -->
        <StackPanel Orientation="Horizontal"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,12">

            <TextBlock Text="ابحث باسم العميل:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="0,0,8,0"/>

            <TextBox x:Name="CustomerSearchBox"
                     Width="180" Height="30"
                     FontSize="14"
                     ToolTip="ابحث باسم العميل"
                     TextChanged="SearchBox_TextChanged"
                     Margin="0,0,12,0"/>

            <TextBlock Text="ابحث بالإجمالي:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="12,0,8,0"/>

            <TextBox x:Name="TotalSearchBox"
                     Width="150" Height="30"
                     FontSize="14"
                     ToolTip="ابحث بسعر الإجمالي"
                     TextChanged="SearchBox_TextChanged"
                     Margin="0,0,12,0"/>

            <Button Content="مسح"
                    Width="70"
                    Click="ClearFilters_Click"/>
        </StackPanel>

        <!-- 🔹 جدول الطلبات -->
        <DataGrid x:Name="OrdersGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  RowHeight="36"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Margin="0,6,0,0"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="رقم" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="التاريخ" Binding="{Binding Date}" Width="150"/>
                <DataGridTextColumn Header="نوع" Binding="{Binding OrderType}" Width="90"/>
                <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="180"/>
                <DataGridTextColumn Header="الطاولة" Binding="{Binding TableId}" Width="90"/>

                <!-- 🔹 الطيار (عرض فقط) -->
                <DataGridTextColumn Header="الطيار"
                                    Binding="{Binding DeliveryPerson}"
                                    Width="150"/>

                <DataGridTextColumn Header="الإجمالي"
                                    Binding="{Binding TotalPrice}"
                                    Width="110"/>

                <!-- 🔹 تحكم -->
                <DataGridTemplateColumn Header="تحكم" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="عرض"
                                        Width="60"
                                        Margin="2"
                                        Click="View_Click"
                                        Background="#03A9F4"
                                        Foreground="White"/>
                                <Button Content="🖨️"
                                        Width="40"
                                        Margin="2"
                                        Click="Print_Click"
                                        Background="#4CAF50"
                                        Foreground="White"/>
                                <Button Content="إضافة طيار"
                                        Width="90"
                                        Margin="2"
                                        Click="AddPilot_Click"
                                        Background="#FF9800"
                                        Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
