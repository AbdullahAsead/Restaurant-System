<Window x:Class="Restaurant_System.CustomersData"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="بيانات العملاء"
        WindowStartupLocation="CenterScreen"
        Height="620" Width="1000"
        Background="#FAFAFA">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- ستايل أزرار الإجراءات داخل الجدول: استخدمنا Template مع Border يدعم CornerRadius -->
        <Style x:Key="GridActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF59D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- عنوان الصفحة -->
        <TextBlock Text="📋 بيانات العملاء"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#1976D2"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- منطقة البحث -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,15">

            <!-- مربع بحث بالاسم -->
            <Grid Width="200" Height="35" Margin="5">
                <TextBox x:Name="NameSearchBox" FontSize="14" Padding="6,4"/>
                <TextBlock Text="ابحث بالاسم"
                           Foreground="Gray"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           FontSize="13"
                           Visibility="{Binding Text.IsEmpty, ElementName=NameSearchBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <!-- مربع بحث برقم الهاتف -->
            <Grid Width="200" Height="35" Margin="5">
                <TextBox x:Name="PhoneSearchBox" FontSize="14" Padding="6,4"/>
                <TextBlock Text="ابحث برقم الهاتف"
                           Foreground="Gray"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           FontSize="13"
                           Visibility="{Binding Text.IsEmpty, ElementName=PhoneSearchBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <Button Content="🔍 بحث"
                    Width="100"
                    Height="35"
                    Margin="5"
                    Background="#1976D2"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="SearchButton_Click"/>

            <Button Content="🧹 مسح"
                    Width="100"
                    Height="35"
                    Margin="5"
                    Background="#BDBDBD"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="ClearSearchButton_Click"/>
        </StackPanel>

        <!-- جدول عرض البيانات داخل Border (Border يدعم CornerRadius مباشرة) -->
        <Border Grid.Row="2" BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="8" Background="White">
            <DataGrid x:Name="CustomersDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      RowHeight="38"
                      FontSize="14"
                      Margin="6"
                      AlternatingRowBackground="#E3F2FD"
                      GridLinesVisibility="All"
                      BorderThickness="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      ColumnWidth="*">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="180"/>
                    <DataGridTextColumn Header="العنوان" Binding="{Binding Address}" Width="220"/>
                    <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="150"/>
                    <DataGridTextColumn Header="هاتف بديل" Binding="{Binding AlternatePhone}" Width="150"/>
                    <DataGridTextColumn Header="تاريخ الإنشاء" Binding="{Binding CreatedAt, StringFormat=d}" Width="130"/>

                    <DataGridTemplateColumn Header="التحكم" Width="170" MinWidth="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- استخدمنا GridActionButtonStyle لكن غيّرنا الخلفية حسب الوظيفة -->
                                    <Button Content="✏️"
                                            Background="#FFF59D"
                                            Foreground="Black"
                                            Style="{StaticResource GridActionButtonStyle}"
                                            Width="60"
                                            Click="EditCustomer_Click"/>
                                    <Button Content="🗑️"
                                            Background="#EF5350"
                                            Foreground="White"
                                            Style="{StaticResource GridActionButtonStyle}"
                                            Width="60"
                                            Click="DeleteCustomer_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
