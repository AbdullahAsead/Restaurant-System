<Window x:Class="Restaurant_System.ViewEditItems"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="عرض وتعديل العناصر"
        Height="550"
        Width="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#FAFAFA">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🔍 منطقة البحث -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <!-- بحث بالاسم -->
            <Grid Width="200" Height="35" Margin="5">
                <TextBox x:Name="NameSearchBox" FontSize="14" Padding="6,4"/>
                <TextBlock Text="ابحث بالاسم"
                           Foreground="Gray"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           FontSize="13"
                           Visibility="{Binding Text.IsEmpty, ElementName=NameSearchBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <!-- بحث بالسعر -->
            <Grid Width="200" Height="35" Margin="5">
                <TextBox x:Name="PriceSearchBox" FontSize="14" Padding="6,4"/>
                <TextBlock Text="ابحث بالسعر"
                           Foreground="Gray"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           FontSize="13"
                           Visibility="{Binding Text.IsEmpty, ElementName=PriceSearchBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <!-- أزرار -->
            <Button Content="🔍 بحث"
                    Width="100"
                    Height="35"
                    Margin="5"
                    Background="#1976D2"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="SearchButton_Click"/>
            <Button Content="🧹 مسح"
                    Width="100"
                    Height="35"
                    Margin="5"
                    Background="#BDBDBD"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="ClearSearchButton_Click"/>
        </StackPanel>

        <!-- ✅ جدول عرض البيانات -->
        <DataGrid x:Name="ItemsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Margin="0,0,0,10"
                  AlternatingRowBackground="#E3F2FD"
                  GridLinesVisibility="All"
                  BorderBrush="#90CAF9"
                  BorderThickness="1"
                  RowHeight="35"
                  FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn Header="الوصف" Binding="{Binding Description}" Width="220"/>
                <DataGridTextColumn Header="السعر" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="القسم" Binding="{Binding CategoryName}" Width="160"/>
                <DataGridTemplateColumn Header="تعديل" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✏️" Click="Edit_Click" Background="#FFF59D" Padding="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="حذف" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑️" Click="Delete_Click" Background="#EF5350" Foreground="White" Padding="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- زر الإغلاق -->
        <Button Content="إغلاق"
                Grid.Row="2"
                Width="90"
                Height="35"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Background="#2196F3"
                Foreground="White"
                FontWeight="Bold"
                Click="Close_Click"/>
    </Grid>
</Window>
