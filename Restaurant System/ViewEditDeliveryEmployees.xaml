<Window x:Class="Restaurant_System.ViewEditDeliveryEmployees"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدارة مندوبي التوصيل"
        Height="520"
        Width="820"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Window.Resources>
        <Style x:Key="GridActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔹 العنوان -->
        <TextBlock Text="🚴 إدارة مندوبي التوصيل"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#1976D2"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- 🔹 البحث -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">

            <!-- البحث بالاسم -->
            <Grid Margin="5">
                <TextBox x:Name="NameSearchBox"
                         Width="180"
                         Height="30"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Text="ابحث بالاسم"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=NameSearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- البحث برقم الموبايل -->
            <Grid Margin="5">
                <TextBox x:Name="PhoneSearchBox"
                         Width="180"
                         Height="30"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Text="ابحث برقم الهاتف"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=PhoneSearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- أزرار البحث -->
            <Button Content="🔍 بحث"
                    Width="90"
                    Height="30"
                    Margin="5"
                    Background="#1976D2"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="SearchButton_Click"/>

            <Button Content="🧹 مسح"
                    Width="90"
                    Height="30"
                    Margin="5"
                    Background="#BDBDBD"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="ClearSearchButton_Click"/>
        </StackPanel>

        <!-- 🔹 الجدول -->
        <DataGrid x:Name="DeliveryGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  RowHeight="35"
                  FontSize="14"
                  Margin="0"
                  AlternatingRowBackground="#E3F2FD"
                  GridLinesVisibility="All"
                  BorderBrush="#90CAF9"
                  BorderThickness="1">

            <DataGrid.Columns>
                <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding PhoneNumber}" Width="*"/>
                <DataGridTextColumn Header="نوع الدراجة" Binding="{Binding MachineType}" Width="*"/>
                <DataGridTextColumn Header="رقم الدراجة" Binding="{Binding MachineNumber}" Width="*"/>

                <DataGridTemplateColumn Header="تحكم" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="✏️ تعديل"
                                        Background="#FFF59D"
                                        Foreground="Black"
                                        Style="{StaticResource GridActionButtonStyle}"
                                        Click="Edit_Click"/>
                                <Button Content="🗑️ حذف"
                                        Background="#EF5350"
                                        Foreground="White"
                                        Style="{StaticResource GridActionButtonStyle}"
                                        Click="Delete_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
