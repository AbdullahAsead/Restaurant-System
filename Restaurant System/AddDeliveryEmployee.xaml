<Window x:Class="Restaurant_System.AddDeliveryEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add Delivery Employee"
        Height="550" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="20">
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="10">

            <!-- عنوان مع أيقونة -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="AccountPlus" Width="30" Height="30" Foreground="#2196F3" Margin="0,0,10,0"/>
                <TextBlock Text="Add Delivery Employee" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="#333"/>
            </StackPanel>

            <TextBlock Text="Name:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="NameTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Phone Number:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="PhoneNumberTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Machine Type:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="MachineTypeTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Machine Number:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="MachineNumberTextBox" Margin="0,0,0,20"/>

            <Button Content="Add Employee"
                    Click="AddEmployee_Click"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"
                    Height="40"
                   />
        </StackPanel>
    </Grid>
</Window>
