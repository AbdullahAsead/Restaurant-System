<Window x:Class="Restaurant_System.ClearSalesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تقرير الورديه"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FlowDirection="RightToLeft">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- عنوان -->
        <TextBlock Text="📋 تقرير الورديه التفصيلي"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#1976D2"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- التاريخ + زر عرض -->

        <!-- المحتوى: عمودان (تيك أواي و توصيل) + تحتهم جدول رسوم التوصيل -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <!-- فاصل -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- تيك أواي / صالة -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="🍽️ مبيعات التيك أواي / الصالة" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,6"/>
                <DataGrid x:Name="TakeawayDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          FontSize="14"
                          RowHeight="34"
                          Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم المنتج" Binding="{Binding ProductName}" Width="2*" />
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="*" />
                        <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, StringFormat=N2}" Width="*" />
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total, StringFormat=N2}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- توصيل -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="🚚 مبيعات التوصيل" FontSize="18" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,6"/>
                <DataGrid x:Name="DeliveryDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          FontSize="14"
                          RowHeight="34"
                          Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم المنتج" Binding="{Binding ProductName}" Width="2*" />
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="*" />
                        <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, StringFormat=N2}" Width="*" />
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total, StringFormat=N2}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- جدول خدمات التوصيل تحت الجدولين (يشغل العرض كامل) -->
            <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Margin="0,250,0,0">
                <TextBlock Text="💳 جدول خدمات التوصيل (OrderId - DeliveryFee)" FontSize="16" FontWeight="Bold" Foreground="#6A1B9A" Margin="0,6,0,6"/>
                <DataGrid x:Name="DeliveryFeesDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          FontSize="13"
                          RowHeight="30">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الأوردر" Binding="{Binding OrderId}" Width="*" />
                        <DataGridTextColumn Header="قيمة التوصيل (ج)" Binding="{Binding DeliveryFee, StringFormat=N2}" Width="*" />
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Date}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>

        <!-- الاجماليات والازرار -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Grid.Column="0">
                <TextBlock x:Name="TakeawayTotalText" FontSize="15" FontWeight="Bold" Foreground="Green" Margin="0,0,0,4"/>
                <TextBlock x:Name="DeliveryTotalText" FontSize="15" FontWeight="Bold" Foreground="DarkOrange" Margin="0,0,0,4"/>
                <TextBlock x:Name="GrandTotalText" FontSize="16" FontWeight="Bold" Foreground="DarkBlue"/>
            </StackPanel>

            <Button Content="🧹 تصفير" Width="110" Height="36" Background="Red" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Click="ClearButton_Click" Grid.Column="1"/>
            <Button Content="🖨️ طباعة" Width="110" Height="36" Background="#2196F3" Foreground="White" FontWeight="Bold" Click="PrintButton_Click" Grid.Column="2"/>
        </Grid>
    </Grid>
</Window>
